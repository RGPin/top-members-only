<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recent Posts</title>
  <link rel="stylesheet" href="/index.css" />
</head>
<body>
  <%- include("partials/header.ejs") %>

  <main class="feed-container">
    <h2>Recent Posts</h2>
    
    <% if (posts.length === 0) { %>
      <p class="no-posts">No posts to display yet!</p>
    <% } else { %>
      <ul class="posts-list">
        <% posts.forEach(post => { %>
          <li>
            <a href="/posts/<%= post.id %>" class="post-card-link">
              <article class="post-card">
                
                <div class="post-header">
                  <!-- Conditional Username and Full Name Logic -->
                  <% if (locals.currentUser) { %>
                    <strong class="author-name">
                      <%= post.firstname %> <%= post.lastname %>
                    </strong>
                    <span class="author-username">@<%= post.username %></span>
                  <% } else { %>
                    <strong class="author-name text-muted">Anonymous</strong>
                  <% } %>
                </div>

                <p class="post-content"><%= post.content %></p>

                <div class="post-footer">
                  <time datetime="<%= post.created_at %>">
                    <%= new Date(post.created_at).toLocaleDateString('en-US', { 
                      month: 'short', 
                      day: 'numeric', 
                      year: 'numeric'
                    }) %>
                  </time>
                  <span class="view-thread">Click to view thread →</span>
                </div>

              </article>
            </a>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </main>
</body>
</html>