<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <link rel="stylesheet" href="/index.css" />
</head>
<body>
  <%- include("partials/header.ejs") %>

  <main class="feed-container">
    <article class="post-card detail-card">
      <div class="post-header">
        <% if (locals.currentUser) { %>
          <strong class="author-name">
            <%= post.firstname %> <%= post.lastname %>
          </strong>
          <span class="author-username">@<%= post.username %></span>
        <% } else { %>
          <strong class="author-name text-muted">Anonymous</strong>
        <% } %>
      </div>

      <p class="post-content-large"><%= post.content %></p>

      <div class="post-footer">
        <time datetime="<%= post.created_at %>">
          <%= new Date(post.created_at).toLocaleDateString('en-US', { 
            weekday: 'long',
            month: 'short', 
            day: 'numeric', 
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
          }) %>
        </time>
      </div>
    </article>

    <section class="comments-section">
      <h3>Comments</h3>
      <p class="text-muted">Comments feature coming soon! 💬</p>
    </section>
  </main>
</body>
</html>