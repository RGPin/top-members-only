<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <link rel="stylesheet" href="/index.css" />
</head>
<body>
  <header class="main-header">
    <div class="header-container">
      <a href="/" class="logo">🚀 MiniSocial</a>
      <a href="/" class="btn btn-secondary">← Back to Feed</a>
    </div>
  </header>

  <main class="feed-container">
    <article class="post-card detail-card">
      <div class="post-header">
        <strong class="author-name"><%= post.firstname %> <%= post.lastname %></strong>
        <span class="author-username">@<%= post.username %></span>
      </div>

      <p class="post-content-large"><%= post.content %></p>

      <div class="post-footer">
        <time datetime="<%= post.created_at %>">
          <%= new Date(post.created_at).toLocaleDateString('en-US', { 
            weekday: 'long',
            month: 'short', 
            day: 'numeric', 
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
          }) %>
        </time>
      </div>
    </article>

    <section class="comments-section">
      <h3>Comments</h3>
      <p class="text-muted">Comments feature coming soon! 💬</p>
    </section>
  </main>
</body>
</html>